{
  "name": "@openlineops/desktop",
  "productName": "OpenLineOps",
  "version": "0.1.0",
  "private": true,
  "description": "OpenLineOps Electron desktop shell.",
  "author": "OpenLineOps contributors",
  "license": "MIT",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "build": "node scripts/clean-electron-build.mjs && tsc -p tsconfig.electron.json && vite build",
    "build:electron": "node scripts/clean-electron-build.mjs && tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "dev": "npm run build:electron && node scripts/dev-launcher.mjs",
    "package:win": "npm run build && npm run package:win:ci",
    "package:win:ci": "node scripts/package-win-unpacked.mjs",
    "smoke:e2e": "npm run build && node scripts/electron-smoke.mjs",
    "smoke:dev-launcher-shutdown": "npm run build:electron && node scripts/dev-launcher-shutdown-smoke.mjs",
    "smoke:e2e:packaged": "npm run package:win && node scripts/electron-smoke.mjs --packaged",
    "smoke:e2e:packaged-existing": "node scripts/electron-smoke.mjs --packaged",
    "smoke:e2e:packaged-default-user-data": "node --check scripts/packaged-default-user-data-smoke.mjs && node scripts/packaged-default-user-data-smoke.mjs",
    "e2e:production-closure:packaged": "node --check scripts/electron-cdp-harness.mjs && node --check scripts/production-closure-e2e.mjs && node scripts/production-closure-e2e.mjs",
    "e2e:production-closure:package-and-run": "npm run package:win && npm run e2e:production-closure:packaged",
    "test:line-projection": "node scripts/line-runtime-projection-test.mjs",
    "test:production-route-runtime": "node scripts/production-route-runtime-projection-test.mjs",
    "test:editor-workspace": "node scripts/editor-workspace-test.mjs",
    "test:draft-transition-guard": "node --test scripts/draft-transition-guard-test.mjs",
    "test:process-problem-location": "node scripts/process-problem-location-test.mjs",
    "test:topology-draft-workspace": "node --test scripts/topology-draft-workspace-test.mjs",
    "test:configuration-draft-workspace": "node --test scripts/configuration-draft-workspace-test.mjs",
    "test:runtime-monitoring-fail-closed": "node --test scripts/runtime-monitoring-fail-closed-test.mjs",
    "test:api-credential-security": "npm run build:electron && node --test scripts/api-credential-security-test.mjs scripts/backend-api-security-test.mjs",
    "test:extension-import-security": "npm run build:electron && node --test scripts/application-extension-import-security-test.mjs",
    "test:external-program-directory-import": "npm run build:electron && node --test scripts/external-program-directory-import-security-test.mjs scripts/external-program-directory-selection-test.mjs",
    "test:trace-artifact-save": "npm run build:electron && node --test scripts/trace-artifact-save-test.mjs",
    "test:runtime-data-binding": "npm run build:electron && node --test scripts/packaged-runtime-data-binding-test.mjs",
    "test:production-route-validation": "node scripts/production-route-validation-test.mjs && node scripts/production-problem-location-test.mjs",
    "test:production-route-layout": "node scripts/production-route-layout-test.mjs",
    "test:production-command-policy": "node scripts/production-run-command-policy-test.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "blockly": "^13.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.4",
    "electron": "^42.5.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
