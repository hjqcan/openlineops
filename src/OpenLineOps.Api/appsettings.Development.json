{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenLineOps": {
    "Runtime": {
      "Persistence": {
        "Provider": "InMemory"
      },
      "Coordination": {
        "Provider": "InMemory"
      },
      "AgentTransport": {
        "Provider": "Disabled"
      },
      "StationExecution": {
        "Provider": "InProcess"
      }
    },
    "Traceability": {
      "Persistence": {
        "Provider": "InMemory"
      }
    }
  }
}
