<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\tools\OpenLineOps.VendorTestHelper\OpenLineOps.VendorTestHelper.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <Target Name="CopyVendorTestHelper" AfterTargets="Build">
    <ItemGroup>
      <VendorTestHelperFile Include="$(MSBuildProjectDirectory)\..\..\tools\OpenLineOps.VendorTestHelper\bin\$(Configuration)\$(TargetFramework)\*" />
    </ItemGroup>
    <Copy SourceFiles="@(VendorTestHelperFile)"
          DestinationFolder="$(OutDir)vendor-helper"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
